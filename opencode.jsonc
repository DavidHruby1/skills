{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": false,
    "lsp": true,
    "mcp": {
        "duckduckgo": {
            "type": "local",
            "command": ["uvx", "duckduckgo-mcp-server"],
            "enabled": true,
        },
    },
    "permission": {
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "todowrite": "allow",
        "question": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "skill": "allow",
        "lsp": "allow",
        "mcp": "allow",
        "read": {
            "*": "allow",
            "**/.env": "ask",
            "**/.env.*": "ask",
            "**/*.env": "ask",
            "**/*.env.*": "ask",
        },
        "edit": {
            "*": "allow",
            "**/.env": "ask",
            "**/.env.*": "ask",
            "**/*.env": "ask",
            "**/*.env.*": "ask",
        },
        "external_directory": {
            "*": "allow",
        },
        "bash": {
            "*": "allow",
            "rm *": "ask",
            "mv *": "ask",
            "cp *": "ask",
            "chmod *": "ask",
            "chown *": "ask",
            "sudo *": "ask",
            "git reset *": "ask",
            "git clean *": "ask",
            "git checkout *": "ask",
            "git restore *": "ask",
            "docker *": "ask",
            "docker-compose *": "ask",
            "kubectl *": "ask",
            "helm *": "ask",
            "npm publish*": "ask",
            "pnpm publish*": "ask",
            "yarn publish*": "ask",
            "bun publish*": "ask",
            "curl *": "ask",
            "wget *": "ask",
            "ssh *": "ask",
            "scp *": "ask",
            "rsync *": "ask",
        },
    },
    "provider": {
        "openai": {
            "models": {
                "gpt-5.6": {
                    "variants": {
                        "max": {
                            "reasoningEffort": "max",
                        },
                    },
                },
                "gpt-5.6-sol": {
                    "variants": {
                        "max": {
                            "reasoningEffort": "max",
                        },
                    },
                },
                "gpt-5.6-terra": {
                    "variants": {
                        "max": {
                            "reasoningEffort": "max",
                        },
                    },
                },
                "gpt-5.6-luna": {
                    "variants": {
                        "max": {
                            "reasoningEffort": "max",
                        },
                    },
                },
            },
        },
    },
    "agent": {
        "plan": {
            "model": "openai/gpt-5.6-sol",
            "variant": "medium",
            "color": "#5d8df5"
        },
        "build": {
            "model": "openai/gpt-5.6-sol",
            "variant": "low",
            "color": "#f0981d"
        },
        "explore": {
            "model": "opencode/deepseek-v4-flash-free",
            "variant": "medium"
        },
        "docu-writer": {
            "model": "openai/gpt-5.4-mini",
            "variant": "high"
        },
        "internal-researcher": {
            "model": "openai/gpt-5.6-luna",
            "variant": "high"
        },
        "external-researcher": {
            "model": "openai/gpt-5.6-luna",
            "variant": "high"
        },
        "code-mapper": {
            "model": "openai/gpt-5.6-luna",
            "variant": "high"
        },
        "brief-auditor": {
            "model": "openai/gpt-5.6-sol",
            "variant": "low"
        },
        "plan-auditor": {
            "model": "openai/gpt-5.6-sol",
            "variant": "low"
        },
        "worker": {
            "model": "openai/gpt-5.6-sol",
            "variant": "low"
        },
        "inspector": {
            "model": "openai/gpt-5.6-sol",
            "variant": "medium"
        }
    },
    "plugin": ["./plugins/graphify.js", "./plugins/codex-identity.js"],
}
